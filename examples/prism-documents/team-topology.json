{
  "$schema": "https://github.com/grokify/prihttps://github.com/grokify/prism/schema/prism-maturity-plan.schema.json",
  "metadata": {
    "name": "Team Topology Example",
    "description": "Example PRISM document demonstrating team topology with services and ownership",
    "version": "1.0.0"
  },
  "domains": [
    {
      "name": "operations",
      "description": "Operational metrics",
      "weight": 0.5
    },
    {
      "name": "security",
      "description": "Security metrics",
      "weight": 0.3
    },
    {
      "name": "quality",
      "description": "Quality metrics",
      "weight": 0.2
    }
  ],
  "layers": [
    {
      "id": "requirements",
      "name": "Requirements",
      "description": "Product ideation, specifications, and design"
    },
    {
      "id": "code",
      "name": "Code",
      "description": "Application code and dependencies"
    },
    {
      "id": "infra",
      "name": "Infrastructure",
      "description": "Cloud resources and platform services"
    },
    {
      "id": "runtime",
      "name": "Runtime",
      "description": "Running services and workloads"
    },
    {
      "id": "adoption",
      "name": "Adoption",
      "description": "Product analytics, user engagement, and self-service"
    },
    {
      "id": "support",
      "name": "Support",
      "description": "Customer support, incident management, and escalations"
    }
  ],
  "teams": [
    {
      "id": "security-team",
      "name": "Security Team",
      "description": "Defines and enforces security standards across the organization",
      "type": "overlay",
      "domain": "security",
      "owner": "Jane Smith",
      "slack": "#security",
      "email": "security@example.com"
    },
    {
      "id": "qe-team",
      "name": "Quality Engineering",
      "description": "Defines quality standards and testing practices",
      "type": "overlay",
      "domain": "quality",
      "owner": "Bob Johnson",
      "slack": "#quality"
    },
    {
      "id": "platform-team",
      "name": "Platform Engineering",
      "description": "Provides infrastructure and developer tooling",
      "type": "platform",
      "layerAccountability": ["infra"],
      "serviceIds": ["kubernetes-platform", "observability-stack"],
      "owner": "Alice Chen",
      "slack": "#platform"
    },
    {
      "id": "payments-team",
      "name": "Payments Team",
      "description": "Owns the payments domain end-to-end",
      "type": "stream_aligned",
      "layerAccountability": ["code", "runtime"],
      "serviceIds": ["payments-api", "payments-worker"],
      "owner": "Charlie Brown",
      "slack": "#payments"
    },
    {
      "id": "users-team",
      "name": "User Management Team",
      "description": "Owns user management and authentication",
      "type": "stream_aligned",
      "layerAccountability": ["code", "runtime"],
      "serviceIds": ["users-api"],
      "owner": "Diana Prince",
      "slack": "#users"
    },
    {
      "id": "product-team",
      "name": "Product Team",
      "description": "Owns product requirements and adoption metrics",
      "type": "stream_aligned",
      "layerAccountability": ["requirements", "adoption"],
      "serviceIds": ["product-analytics"],
      "owner": "Eve Wilson",
      "slack": "#product"
    },
    {
      "id": "support-team",
      "name": "Customer Support",
      "description": "Handles customer support and escalations",
      "type": "stream_aligned",
      "layerAccountability": ["support"],
      "serviceIds": ["support-portal", "ticketing-system"],
      "owner": "Frank Miller",
      "slack": "#support"
    }
  ],
  "services": [
    {
      "id": "kubernetes-platform",
      "name": "Kubernetes Platform",
      "description": "Internal Kubernetes platform",
      "ownerTeamId": "platform-team",
      "layerId": "infra",
      "tier": "tier1"
    },
    {
      "id": "observability-stack",
      "name": "Observability Stack",
      "description": "Monitoring, logging, and tracing infrastructure",
      "ownerTeamId": "platform-team",
      "layerId": "infra",
      "tier": "tier1"
    },
    {
      "id": "payments-api",
      "name": "Payments API",
      "description": "Core payments processing service",
      "ownerTeamId": "payments-team",
      "layerId": "runtime",
      "tier": "tier1",
      "repository": "https://github.com/example/payments-api",
      "metricIds": ["slo-payments-availability", "slo-payments-latency"]
    },
    {
      "id": "payments-worker",
      "name": "Payments Worker",
      "description": "Async payment processing jobs",
      "ownerTeamId": "payments-team",
      "layerId": "runtime",
      "tier": "tier2"
    },
    {
      "id": "users-api",
      "name": "Users API",
      "description": "User management and authentication service",
      "ownerTeamId": "users-team",
      "layerId": "runtime",
      "tier": "tier1",
      "repository": "https://github.com/example/users-api"
    },
    {
      "id": "product-analytics",
      "name": "Product Analytics",
      "description": "User engagement and adoption tracking",
      "ownerTeamId": "product-team",
      "layerId": "adoption",
      "tier": "tier2",
      "metricIds": ["metric-feature-adoption", "metric-user-activation"]
    },
    {
      "id": "support-portal",
      "name": "Support Portal",
      "description": "Customer-facing support portal",
      "ownerTeamId": "support-team",
      "layerId": "support",
      "tier": "tier2"
    },
    {
      "id": "ticketing-system",
      "name": "Ticketing System",
      "description": "Internal ticket management system",
      "ownerTeamId": "support-team",
      "layerId": "support",
      "tier": "tier2",
      "metricIds": ["metric-ticket-resolution", "metric-first-contact-resolution"]
    }
  ],
  "metrics": [
    {
      "id": "slo-payments-availability",
      "name": "Payments API Availability",
      "description": "Availability of the payments API",
      "domain": "operations",
      "stage": "runtime",
      "category": "reliability",
      "layer": "runtime",
      "serviceId": "payments-api",
      "metricType": "rate",
      "trendDirection": "higher_better",
      "unit": "%",
      "baseline": 99.0,
      "current": 99.95,
      "target": 99.99,
      "slo": {
        "target": ">=99.99%",
        "operator": "gte",
        "value": 99.99,
        "window": "30d"
      },
      "owner": "Payments Team"
    },
    {
      "id": "slo-payments-latency",
      "name": "Payments API P99 Latency",
      "description": "99th percentile latency",
      "domain": "operations",
      "stage": "runtime",
      "category": "reliability",
      "layer": "runtime",
      "serviceId": "payments-api",
      "metricType": "latency",
      "trendDirection": "lower_better",
      "unit": "ms",
      "baseline": 500,
      "current": 85,
      "target": 100,
      "slo": {
        "target": "<=100ms",
        "operator": "lte",
        "value": 100,
        "window": "7d"
      },
      "owner": "Payments Team"
    },
    {
      "id": "sec-sast-findings",
      "name": "SAST Findings",
      "description": "Static analysis security findings",
      "domain": "security",
      "stage": "build",
      "category": "detection",
      "layer": "code",
      "metricType": "count",
      "trendDirection": "lower_better",
      "baseline": 50,
      "current": 12,
      "target": 0,
      "owner": "Security Team"
    },
    {
      "id": "qa-test-coverage",
      "name": "Test Coverage",
      "description": "Unit test code coverage",
      "domain": "quality",
      "stage": "test",
      "category": "detection",
      "layer": "code",
      "qualityVertical": "functional",
      "metricType": "coverage",
      "trendDirection": "higher_better",
      "unit": "%",
      "baseline": 60,
      "current": 82,
      "target": 80,
      "owner": "QE Team"
    },
    {
      "id": "metric-req-completion",
      "name": "Requirements Completion Rate",
      "description": "Percentage of requirements completed on time",
      "domain": "operations",
      "stage": "design",
      "category": "reliability",
      "layer": "requirements",
      "metricType": "rate",
      "trendDirection": "higher_better",
      "unit": "%",
      "baseline": 70,
      "current": 85,
      "target": 90,
      "owner": "Product Team"
    },
    {
      "id": "metric-feature-adoption",
      "name": "Feature Adoption Rate",
      "description": "Percentage of users adopting new features within 30 days",
      "domain": "operations",
      "stage": "runtime",
      "category": "efficiency",
      "layer": "adoption",
      "serviceId": "product-analytics",
      "metricType": "rate",
      "trendDirection": "higher_better",
      "unit": "%",
      "baseline": 20,
      "current": 45,
      "target": 60,
      "owner": "Product Team"
    },
    {
      "id": "metric-user-activation",
      "name": "User Activation Rate",
      "description": "Percentage of new users completing activation flow",
      "domain": "operations",
      "stage": "runtime",
      "category": "reliability",
      "layer": "adoption",
      "serviceId": "product-analytics",
      "metricType": "rate",
      "trendDirection": "higher_better",
      "unit": "%",
      "baseline": 50,
      "current": 72,
      "target": 85,
      "slo": {
        "target": ">=85%",
        "operator": "gte",
        "value": 85,
        "window": "30d"
      },
      "owner": "Product Team"
    },
    {
      "id": "metric-ticket-resolution",
      "name": "Ticket Resolution Time",
      "description": "Average time to resolve support tickets",
      "domain": "operations",
      "stage": "response",
      "category": "reliability",
      "layer": "support",
      "serviceId": "ticketing-system",
      "metricType": "latency",
      "trendDirection": "lower_better",
      "unit": "hours",
      "baseline": 24,
      "current": 8,
      "target": 4,
      "slo": {
        "target": "<=4h",
        "operator": "lte",
        "value": 4,
        "window": "7d"
      },
      "owner": "Support Team"
    },
    {
      "id": "metric-first-contact-resolution",
      "name": "First Contact Resolution",
      "description": "Percentage of tickets resolved on first contact",
      "domain": "operations",
      "stage": "response",
      "category": "efficiency",
      "layer": "support",
      "serviceId": "ticketing-system",
      "metricType": "rate",
      "trendDirection": "higher_better",
      "unit": "%",
      "baseline": 50,
      "current": 68,
      "target": 75,
      "owner": "Support Team"
    }
  ]
}

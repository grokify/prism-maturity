{
  "$schema": "https://github.com/grokify/prihttps://github.com/grokify/prism/schema/prism-maturity-plan.schema.json",
  "metadata": {
    "name": "Operations with Layers Example",
    "description": "Example PRISM document demonstrating layer-based metric organization",
    "version": "1.0.0"
  },
  "domains": [
    {
      "name": "operations",
      "description": "Operational reliability and efficiency metrics",
      "weight": 1.0
    }
  ],
  "layers": [
    {
      "id": "requirements",
      "name": "Requirements",
      "description": "Product ideation, specifications, and design",
      "signals": {
        "traffic": "metric-req-throughput"
      }
    },
    {
      "id": "code",
      "name": "Code",
      "description": "Application code, libraries, and dependencies",
      "signals": {
        "errors": "metric-code-lint-errors"
      }
    },
    {
      "id": "infra",
      "name": "Infrastructure",
      "description": "Cloud resources, networking, and platform services",
      "signals": {
        "saturation": "metric-infra-cpu"
      }
    },
    {
      "id": "runtime",
      "name": "Runtime",
      "description": "Running services, containers, and workloads",
      "signals": {
        "latency": "metric-runtime-p99",
        "traffic": "metric-runtime-rps",
        "errors": "metric-runtime-errors",
        "saturation": "metric-runtime-cpu"
      }
    },
    {
      "id": "adoption",
      "name": "Adoption",
      "description": "Product analytics, user engagement, and self-service",
      "signals": {
        "traffic": "metric-adoption-dau",
        "errors": "metric-adoption-churn"
      }
    },
    {
      "id": "support",
      "name": "Support",
      "description": "Customer support, incident management, and escalations",
      "signals": {
        "latency": "metric-support-resolution-time",
        "traffic": "metric-support-ticket-volume",
        "errors": "metric-support-escalation-rate"
      }
    }
  ],
  "metrics": [
    {
      "id": "metric-code-lint-errors",
      "name": "Linting Errors",
      "description": "Number of linting errors in codebase",
      "domain": "operations",
      "stage": "build",
      "category": "quality",
      "layer": "code",
      "metricType": "count",
      "trendDirection": "lower_better",
      "baseline": 50,
      "current": 12,
      "target": 0
    },
    {
      "id": "metric-code-deps-outdated",
      "name": "Outdated Dependencies",
      "description": "Number of outdated dependencies",
      "domain": "operations",
      "stage": "build",
      "category": "quality",
      "layer": "code",
      "metricType": "count",
      "trendDirection": "lower_better",
      "baseline": 25,
      "current": 8,
      "target": 0
    },
    {
      "id": "metric-infra-compliance",
      "name": "Infrastructure Compliance",
      "description": "Percentage of infrastructure resources compliant with policies",
      "domain": "operations",
      "stage": "build",
      "category": "reliability",
      "layer": "infra",
      "metricType": "rate",
      "trendDirection": "higher_better",
      "unit": "%",
      "baseline": 75,
      "current": 92,
      "target": 100
    },
    {
      "id": "metric-infra-cpu",
      "name": "Infrastructure CPU Utilization",
      "description": "Average CPU utilization across infrastructure",
      "domain": "operations",
      "stage": "runtime",
      "category": "efficiency",
      "layer": "infra",
      "metricType": "rate",
      "trendDirection": "target_value",
      "unit": "%",
      "baseline": 80,
      "current": 55,
      "target": 60
    },
    {
      "id": "metric-runtime-p99",
      "name": "P99 Response Latency",
      "description": "99th percentile response latency",
      "domain": "operations",
      "stage": "runtime",
      "category": "reliability",
      "layer": "runtime",
      "metricType": "latency",
      "trendDirection": "lower_better",
      "unit": "ms",
      "baseline": 500,
      "current": 95,
      "target": 100,
      "sli": {
        "name": "Response Latency",
        "description": "P99 response time for API requests",
        "sliType": "latency"
      },
      "slo": {
        "target": "<=100ms",
        "operator": "lte",
        "value": 100,
        "window": "7d"
      }
    },
    {
      "id": "metric-runtime-rps",
      "name": "Requests Per Second",
      "description": "Traffic throughput",
      "domain": "operations",
      "stage": "runtime",
      "category": "efficiency",
      "layer": "runtime",
      "metricType": "count",
      "unit": "req/s",
      "baseline": 1000,
      "current": 2500,
      "target": 5000,
      "sli": {
        "name": "Request Rate",
        "description": "Traffic throughput in requests per second",
        "sliType": "throughput"
      }
    },
    {
      "id": "metric-runtime-errors",
      "name": "Error Rate",
      "description": "Percentage of requests resulting in errors",
      "domain": "operations",
      "stage": "runtime",
      "category": "reliability",
      "layer": "runtime",
      "metricType": "rate",
      "trendDirection": "lower_better",
      "unit": "%",
      "baseline": 5.0,
      "current": 0.5,
      "target": 0.1,
      "sli": {
        "name": "Error Rate",
        "description": "Percentage of failed requests",
        "sliType": "error_rate"
      },
      "slo": {
        "target": "<=0.1%",
        "operator": "lte",
        "value": 0.1,
        "window": "30d"
      }
    },
    {
      "id": "metric-runtime-cpu",
      "name": "Service CPU Utilization",
      "description": "CPU utilization of running services",
      "domain": "operations",
      "stage": "runtime",
      "category": "efficiency",
      "layer": "runtime",
      "metricType": "rate",
      "unit": "%",
      "baseline": 70,
      "current": 45,
      "target": 60,
      "sli": {
        "name": "CPU Saturation",
        "description": "Service CPU utilization as saturation indicator",
        "sliType": "saturation"
      }
    },
    {
      "id": "metric-req-throughput",
      "name": "Requirements Throughput",
      "description": "Number of requirements completed per sprint",
      "domain": "operations",
      "stage": "design",
      "category": "efficiency",
      "layer": "requirements",
      "metricType": "count",
      "trendDirection": "higher_better",
      "unit": "reqs/sprint",
      "baseline": 8,
      "current": 12,
      "target": 15
    },
    {
      "id": "metric-req-clarity",
      "name": "Requirements Clarity Score",
      "description": "Percentage of requirements with acceptance criteria",
      "domain": "operations",
      "stage": "design",
      "category": "quality",
      "layer": "requirements",
      "metricType": "rate",
      "trendDirection": "higher_better",
      "unit": "%",
      "baseline": 60,
      "current": 85,
      "target": 95
    },
    {
      "id": "metric-adoption-dau",
      "name": "Daily Active Users",
      "description": "Number of daily active users",
      "domain": "operations",
      "stage": "runtime",
      "category": "efficiency",
      "layer": "adoption",
      "metricType": "count",
      "trendDirection": "higher_better",
      "baseline": 1000,
      "current": 2500,
      "target": 5000
    },
    {
      "id": "metric-adoption-activation",
      "name": "User Activation Rate",
      "description": "Percentage of new users completing activation",
      "domain": "operations",
      "stage": "runtime",
      "category": "reliability",
      "layer": "adoption",
      "metricType": "rate",
      "trendDirection": "higher_better",
      "unit": "%",
      "baseline": 40,
      "current": 65,
      "target": 80,
      "slo": {
        "target": ">=80%",
        "operator": "gte",
        "value": 80,
        "window": "30d"
      }
    },
    {
      "id": "metric-adoption-churn",
      "name": "Monthly Churn Rate",
      "description": "Percentage of users churning per month",
      "domain": "operations",
      "stage": "runtime",
      "category": "reliability",
      "layer": "adoption",
      "metricType": "rate",
      "trendDirection": "lower_better",
      "unit": "%",
      "baseline": 8.0,
      "current": 3.5,
      "target": 2.0,
      "slo": {
        "target": "<=2%",
        "operator": "lte",
        "value": 2.0,
        "window": "30d"
      }
    },
    {
      "id": "metric-support-resolution-time",
      "name": "Ticket Resolution Time",
      "description": "Average time to resolve support tickets",
      "domain": "operations",
      "stage": "response",
      "category": "reliability",
      "layer": "support",
      "metricType": "latency",
      "trendDirection": "lower_better",
      "unit": "hours",
      "baseline": 48,
      "current": 12,
      "target": 8,
      "slo": {
        "target": "<=8h",
        "operator": "lte",
        "value": 8,
        "window": "7d"
      }
    },
    {
      "id": "metric-support-ticket-volume",
      "name": "Support Ticket Volume",
      "description": "Number of support tickets per day",
      "domain": "operations",
      "stage": "runtime",
      "category": "efficiency",
      "layer": "support",
      "metricType": "count",
      "unit": "tickets/day",
      "baseline": 100,
      "current": 45,
      "target": 30
    },
    {
      "id": "metric-support-escalation-rate",
      "name": "Escalation Rate",
      "description": "Percentage of tickets requiring escalation",
      "domain": "operations",
      "stage": "response",
      "category": "reliability",
      "layer": "support",
      "metricType": "rate",
      "trendDirection": "lower_better",
      "unit": "%",
      "baseline": 25,
      "current": 10,
      "target": 5,
      "slo": {
        "target": "<=5%",
        "operator": "lte",
        "value": 5,
        "window": "30d"
      }
    },
    {
      "id": "metric-support-csat",
      "name": "Customer Satisfaction",
      "description": "Customer satisfaction score from support interactions",
      "domain": "operations",
      "stage": "response",
      "category": "quality",
      "layer": "support",
      "metricType": "score",
      "trendDirection": "higher_better",
      "unit": "/5",
      "baseline": 3.5,
      "current": 4.2,
      "target": 4.5
    }
  ]
}
